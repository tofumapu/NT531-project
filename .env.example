# ─── AI SRE Agent ─────────────────────────────────────────────────────────────
# Internal service URLs (in-cluster defaults shown)
DECISION_LOG_URL=http://decision-log.monitoring.svc.cluster.local:8000
PROMETHEUS_URL=http://prom-stack-kube-prometheus-prometheus.monitoring.svc.cluster.local:9090
ALERTMANAGER_URL=http://prom-stack-kube-prometheus-alertmanager.monitoring.svc.cluster.local:9093

# LLM Gateway (OpenAI-compatible, e.g. 9Router tunnel URL)
# When running locally: http://172.22.240.1:20128/v1
# When on AKS:         https://<cloudflare-tunnel>/v1
LLM_BASE_URL=https://<your-llm-gateway>/v1
LLM_MODEL=devops-test-agent
LLM_TIMEOUT_SECONDS=30

# Agent safety knobs
MAX_ACTIONS_PER_MINUTE=3
MIN_CONFIDENCE_FOR_ACTION=0.7
AGENT_DRY_RUN=false
REMEDIATION_TIMEOUT_SECONDS=180

# ─── Telegram notifications (optional) ────────────────────────────────────────
# Create k8s secret:
#   kubectl -n monitoring create secret generic agent-telegram \
#     --from-literal=TELEGRAM_BOT_TOKEN="123:ABC..." \
#     --from-literal=TELEGRAM_CHAT_ID="-1001234567890"
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_RESOLVED=true

# ─── Azure DevOps integration (pipeline_rerun action) ─────────────────────────
# Create k8s secret:
#   kubectl -n monitoring create secret generic agent-azdo \
#     --from-literal=AZDO_PAT="<your-personal-access-token>"
AZDO_ORG=<your-azure-devops-org>
AZDO_PROJECT=<your-project-name>
AZDO_PIPELINE_ID=<pipeline-id>
AZDO_BRANCH=main
AZDO_PAT=

# ─── ArgoCD integration (argocd_sync action) ──────────────────────────────────
ARGOCD_APP_NAME=voteapp-service
ARGOCD_NAMESPACE=argocd

# ─── PostgreSQL (development — change for production!) ────────────────────────
POSTGRES_USER=<your-db-user>
POSTGRES_PASSWORD=<your-db-password>
POSTGRES_DB=votes

# ─── Container Registry ───────────────────────────────────────────────────────
# ACR image pull secret:
#   kubectl create secret docker-registry acr-secret \
#     --docker-server=<acr>.azurecr.io \
#     --docker-username=<sp-id> \
#     --docker-password=<sp-secret>
ACR_REGISTRY=<your-acr>.azurecr.io
